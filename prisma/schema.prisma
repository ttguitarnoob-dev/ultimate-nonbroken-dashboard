// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CarryItem {
  id        String   @id @default(cuid())
  name      String
  item      String
  imageURL  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HazelTube {
  id       Int      @id @default(autoincrement())
  videoIds String[]
}

model HazelSearch {
  id        Int      @id @default(autoincrement())
  query     String
  createdAt DateTime @default(now())
}

model RamyNetLocations {
  id           Int      @id @default(autoincrement())
  latitude     String
  longitude    String
  altitude     String
  ipAddress    String
  imageURL     String?
  locationName String
  createdAt    DateTime @default(now())
}

// BARKING BUBBLES STUFF HERE

model BubblesInquiry {
  id        String @id @default(cuid())
  ownerName String
  dogName   String
  email     String
  inquiry   String
}

enum FurLength {
  SHORT
  MEDIUM
  LONG
}

enum DogSize {
  SMALL
  MEDIUM
  LARGE
}

model AvailabilitySlot {
  id          String       @id @default(cuid())
  startsAt    DateTime     @unique
  createdAt   DateTime     @default(now())

  appointment Appointment?

  @@index([startsAt])
}

model Appointment {
  id                 String           @id @default(cuid())

  ownerName          String
  email              String
  phoneNumber        String?

  dogName            String

  furLength          FurLength
  dogSize            DogSize

  allergy            Boolean
  allergyDescription String?

  location           String
  additionalDetails  String

  slotId             String           @unique
  slot               AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Restrict)

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([email])
}